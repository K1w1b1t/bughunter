# HunterOps production environment template (Linux / Docker)
# Copy to .env and fill secrets before deployment.

# =========================
# Core Runtime
# =========================
HUNTEROPS_HOME=/opt/hunterops
HUNTEROPS_APP_USER=hunterops
HUNTEROPS_ENV=production
HUNTEROPS_RUNTIME_PROFILE=production
HUNTEROPS_DISABLE_UVLOOP=0
HUNTEROPS_COLOR_LOGS=0
HUNTEROPS_DB_OPTIONAL=0
HUNTEROPS_PREFLIGHT_STRICT=1
PLAYWRIGHT_HEADLESS=true
RUN_INTERVAL_SECONDS=300
RUN_MAX_SECONDS=1200
RUN_JITTER_SECONDS=20
RUN_MAX_BACKOFF_SECONDS=300
MONITOR_INTERVAL_HOURS=6
TARGETS_FILE=/opt/hunterops/config/targets/robinhood_in_scope_hosts.txt

# =========================
# HackerOne / Platform Auth
# =========================
H1_API_IDENTIFIER=reaperk0ji
H1_API_TOKEN=
# Program submission headers (Robinhood/HackerOne guideline)
HUNTEROPS_BUG_BOUNTY_USERNAME=reaperk0ji
HUNTEROPS_TEST_ACCOUNT_EMAIL=
HACKERONE_API_USER=
HACKERONE_API_TOKEN=
HACKERONE_PROGRAM_HANDLE=
BUGCROWD_API_TOKEN=

# =========================
# Session Profiles (optional)
# =========================
HUNTEROPS_USER_TOKEN=
HUNTEROPS_USER_COOKIE=
HUNTEROPS_USER_B_TOKEN=
HUNTEROPS_USER_B_COOKIE=
HUNTEROPS_ADMIN_TOKEN=
HUNTEROPS_ADMIN_COOKIE=

# =========================
# Infrastructure (Postgres / Redis)
# =========================
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=hunter
POSTGRES_PASSWORD=change_me
POSTGRES_DB=hunterops
HUNTEROPS_POSTGRES_DSN=postgresql://hunter:change_me@db:5432/hunterops
HUNTEROPS_REDIS_URL=redis://redis:6379/0
HUNTEROPS_PG_CONNECT_TIMEOUT_SECONDS=5
HUNTEROPS_PG_STATEMENT_TIMEOUT_MS=12000
HUNTEROPS_PG_LOCK_TIMEOUT_MS=3000
HUNTEROPS_PG_IDLE_IN_TX_TIMEOUT_MS=20000

# =========================
# HTTP Circuit Breaker / WAF Cooldown
# =========================
HUNTEROPS_CB_429_THRESHOLD=10
HUNTEROPS_CB_COOLDOWN_SECONDS=60

# =========================
# OOB Engine
# =========================
HUNTEROPS_OOB_CALLBACK_DOMAIN=
HUNTEROPS_OOB_POLL_URL=
HUNTEROPS_OOB_API_TOKEN=

# =========================
# Discord / Slack Alerting
# =========================
HUNTEROPS_DISCORD_RESEARCH_WEBHOOK=
HUNTEROPS_DISCORD_CRITICAL_WEBHOOK=
HUNTEROPS_SLACK_RESEARCH_WEBHOOK=
HUNTEROPS_SLACK_CRITICAL_WEBHOOK=

# Legacy/fallback webhook vars supported by modules:
DISCORD_WEBHOOK_URL=
HUNTEROPS_DISCORD_RECON_WEBHOOK=
HUNTEROPS_DISCORD_FINDINGS_WEBHOOK=
HUNTEROPS_CRITICAL_WEBHOOK=
MONITOR_DISCORD_WEBHOOK=

# Optional mobile fallback
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =========================
# Container resource tuning
# =========================
APP_CPUS=2.0
APP_MEM_LIMIT=3g
APP_MEM_RESERVATION=1g
DB_CPUS=1.0
DB_MEM_LIMIT=1g
DB_MEM_RESERVATION=512m
REDIS_CPUS=0.5
REDIS_MEM_LIMIT=256m
REDIS_MEM_RESERVATION=128m
MONITOR_CPUS=0.5
MONITOR_MEM_LIMIT=256m
MONITOR_MEM_RESERVATION=128m
OOB_CPUS=0.5
OOB_MEM_LIMIT=512m
