# =========================
# HunterOps Core Identity
# =========================
HUNTER_NAME=
HUNTER_EMAIL=
HACKERONE_USERNAME=
BUGCROWD_USERNAME=

# =========================
# Database (Postgres 14+)
# =========================
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=hunter
POSTGRES_PASSWORD=change_me
POSTGRES_DB=hunterops
HUNTEROPS_POSTGRES_DSN=postgresql://hunter:change_me@db:5432/hunterops
HUNTEROPS_REDIS_URL=redis://redis:6379/0

# =========================
# API Tokens / Integrations
# =========================
H1_API_IDENTIFIER=reaperk0ji
H1_API_TOKEN=
HACKERONE_API_USER=
HACKERONE_API_TOKEN=
BUGCROWD_API_TOKEN=
HACKERONE_PROGRAM_HANDLE=

# =========================
# Session Profiles (Optional)
# =========================
HUNTEROPS_USER_TOKEN=
HUNTEROPS_USER_COOKIE=
HUNTEROPS_USER_B_TOKEN=
HUNTEROPS_USER_B_COOKIE=
HUNTEROPS_ADMIN_TOKEN=
HUNTEROPS_ADMIN_COOKIE=

# =========================
# Notifications / Mobile Alerts
# =========================
DISCORD_WEBHOOK_URL=
MONITOR_DISCORD_WEBHOOK=
HUNTEROPS_CRITICAL_WEBHOOK=
HUNTEROPS_DISCORD_RECON_WEBHOOK=
HUNTEROPS_DISCORD_FINDINGS_WEBHOOK=
HUNTEROPS_DISCORD_RESEARCH_WEBHOOK=
HUNTEROPS_DISCORD_CRITICAL_WEBHOOK=
HUNTEROPS_SLACK_RESEARCH_WEBHOOK=
HUNTEROPS_SLACK_CRITICAL_WEBHOOK=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =========================
# OOB / External Callback
# =========================
HUNTEROPS_OOB_CALLBACK_DOMAIN=
HUNTEROPS_OOB_POLL_URL=
HUNTEROPS_OOB_API_TOKEN=

# =========================
# Target Inputs
# =========================
TARGETS_FILE=data/targets/in_scope_hosts.txt
TARGET_LIST=

# =========================
# Runtime / Scheduling
# =========================
HUNTEROPS_HOME=/opt/hunterops
RUN_INTERVAL_SECONDS=300
MONITOR_INTERVAL_HOURS=6

# =========================
# Resource Limits (docker-compose)
# =========================
APP_CPUS=1.5
APP_MEM_LIMIT=2g
APP_MEM_RESERVATION=1g
DB_CPUS=1.0
DB_MEM_LIMIT=1g
DB_MEM_RESERVATION=512m
REDIS_CPUS=0.5
REDIS_MEM_LIMIT=256m
REDIS_MEM_RESERVATION=128m
MONITOR_CPUS=0.5
MONITOR_MEM_LIMIT=256m
MONITOR_MEM_RESERVATION=128m
OOB_CPUS=0.5
OOB_MEM_LIMIT=512m
