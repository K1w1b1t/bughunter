# ===================================================================
# HunterOps-AI: Environment Configuration Template (v2.0)
# ===================================================================
# PROJECT: HunterOps-AI Bug Bounty Automation Framework + SOC Virtual
# ENVIRONMENT: Oracle Cloud VPS (Ubuntu 22.04 LTS)
# CLASSIFICATION: SECRETS - Never commit to version control
# GENERATED: 2026-03-20
# ===================================================================

# ==========================
# SECTION 1: INFRASTRUCTURE
# ==========================

# Deployment environment (production, staging, development)
HUNTEROPS_ENV=production
HUNTEROPS_RUNTIME_PROFILE=production
HUNTEROPS_HOME=/opt/hunterops
BUILD_DATE=2026-03-20
GIT_COMMIT=main

# VPS Public IP (used for OOB callbacks + reverse DNS validation)
VPS_PUBLIC_IP=<YOUR_ORACLE_CLOUD_PUBLIC_IP>

# Docker resource limits (CPU cores + memory)
CONCURRENCY=6
DB_CPUS=2
DB_MEM_LIMIT=2g
REDIS_CPUS=1
REDIS_MEM_LIMIT=512m
ENGINE_CPUS=3
ENGINE_MEM_LIMIT=4g

# ==========================
# SECTION 2: POSTGRESQL 16+ (Async + Audit Logging)
# ==========================

# Master credentials (MUST change in production!)
POSTGRES_USER=hunterops
POSTGRES_PASSWORD=<GENERATE_STRONG_32_CHAR_PASSWORD>
POSTGRES_DB=hunterops
POSTGRES_PORT=5432
POSTGRES_HOST=db
HUNTEROPS_POSTGRES_DSN=postgresql://hunterops:<GENERATE_STRONG_32_CHAR_PASSWORD>@db:5432/hunterops
# Compatibility alias supported by preflight/storage:
POSTGRES_DSN=postgresql://hunterops:<GENERATE_STRONG_32_CHAR_PASSWORD>@db:5432/hunterops

# Async SQLAlchemy DSN (auto-constructed at runtime)
# Format: postgresql+asyncpg://user:password@db:5432/database
DATABASE_URL_ASYNC=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# Connection pool (SQLAlchemy 2.0 async mode)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=3600
DB_ECHO_QUERIES=false

# Query timeouts (milliseconds)
HUNTEROPS_PG_CONNECT_TIMEOUT_SECONDS=5
HUNTEROPS_PG_STATEMENT_TIMEOUT_MS=12000
HUNTEROPS_PG_LOCK_TIMEOUT_MS=3000
HUNTEROPS_PG_IDLE_IN_TX_TIMEOUT_MS=20000
HUNTEROPS_LOCAL_DB_FALLBACK=0
HUNTEROPS_LOCAL_POSTGRES_HOST=127.0.0.1

# ==========================
# SECTION 3: REDIS CACHE
# ==========================

# Redis connection
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=<OPTIONAL_REDIS_AUTH>
REDIS_SSL=false
HUNTEROPS_REDIS_URL=redis://redis:6379/0

# Cache TTLs (seconds)
CACHE_TTL_DEFAULT=3600
CACHE_TTL_FINDINGS=86400
CACHE_TTL_TARGETS=604800
CACHE_TTL_SESSIONS=1800

# ==========================
# SECTION 4: LOGGING & OBSERVABILITY (Hybrid)
# ==========================

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
LOG_FORMAT=json

# Structured Logging (Structlog)
STRUCTLOG_ENABLED=true
STRUCTLOG_RENDERER=json
STRUCTLOG_PROCESSORS=comma_separated_list

# Log file paths (inside container, mounted to host)
LOG_FILE_STRUCTURED=/opt/hunterops/data/logs/structured.jsonl
LOG_FILE_FINDINGS=/opt/hunterops/data/logs/findings.jsonl
LOG_FILE_AUDIT=/opt/hunterops/data/logs/audit.jsonl
LOG_FILE_ERRORS=/opt/hunterops/data/logs/errors.jsonl

# Log retention policy
LOG_RETENTION_DAYS=90
LOG_ROTATION_SIZE_MB=100

# ==========================
# SECTION 5: LLM INTEGRATION (Anthropic Claude)
# ==========================

# API Keys (CRITICAL - use HashiCorp Vault in production!)
ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY>
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MAX_TOKENS=4096

# LLM Behavior
LLM_TEMPERATURE=0.3
LLM_TOP_P=0.9
LLM_CACHE_ENABLED=true
LLM_CACHE_TTL=3600

# LLM Resilience
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY_MS=1000
LLM_REQUEST_TIMEOUT_SEC=60

# ==========================
# SECTION 6: SECURITY & RATE LIMITING
# ==========================

# Global rate limiting (non-negotiable)
RATE_LIMIT_PER_SEC=10
RATE_LIMIT_PER_MINUTE=300
RATE_LIMIT_PER_HOUR=12000

# Scope validation (strict enforcement)
SCOPE_VALIDATION_ENABLED=true
SCOPE_ENFORCEMENT_LEVEL=strict
HUNTEROPS_REQUIRE_PROGRAM_MATCH=1
HUNTEROPS_REQUIRE_SIGNED_SCOPE=0
HUNTEROPS_SCOPE_EXPIRY_WARN_DAYS=7

# Encryption for sensitive data
ENCRYPTION_KEY=<GENERATE_32_BYTE_HEX_KEY>
ENCRYPTION_ALGORITHM=AES-256-GCM

# JWT Secrets (service-to-service auth)
JWT_SECRET=<GENERATE_STRONG_SECRET_64_CHARS>
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ==========================
# SECTION 7: DISCORD NOTIFICATIONS (4-Tier Severity)
# ==========================

# Discord Webhook URLs (severity-based routing)
DISCORD_WEBHOOK_CRITICAL=https://discord.com/api/webhooks/<YOUR_CRITICAL_WEBHOOK>
DISCORD_WEBHOOK_HIGH=https://discord.com/api/webhooks/<YOUR_HIGH_WEBHOOK>
DISCORD_WEBHOOK_MEDIUM=https://discord.com/api/webhooks/<YOUR_MEDIUM_WEBHOOK>
DISCORD_WEBHOOK_INFO=https://discord.com/api/webhooks/<YOUR_INFO_WEBHOOK>

# Legacy webhook URLs (backward compatibility)
DISCORD_WEBHOOK_URL=
HUNTEROPS_CRITICAL_WEBHOOK=
HUNTEROPS_DISCORD_FINDINGS_WEBHOOK=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
HUNTEROPS_SLACK_CRITICAL_WEBHOOK=

# Discord Alert Configuration
DISCORD_ENABLED=true
DISCORD_EMBED_COLOR_CRITICAL=16711680
DISCORD_EMBED_COLOR_HIGH=16776960
DISCORD_EMBED_COLOR_MEDIUM=16744448
DISCORD_EMBED_COLOR_INFO=255
DISCORD_MESSAGES_PER_MINUTE=30

# ==========================
# SECTION 8: HACKERONE INTEGRATION
# ==========================

# HackerOne API Credentials
HACKERONE_API_USER=<YOUR_H1_USERNAME>
HACKERONE_API_TOKEN=<YOUR_H1_API_TOKEN>
H1_API_IDENTIFIER=<YOUR_H1_USERNAME>
H1_API_TOKEN=<YOUR_H1_API_TOKEN>
# Optional generic API key alias for integrations/wrappers:
HUNTEROPS_API_KEY=<YOUR_PLATFORM_API_KEY>

# HackerOne Program Configuration
HACKERONE_PROGRAM_HANDLE=<PRIMARY_PROGRAM_HANDLE>
HACKERONE_PROGRAMS=program1,program2,program3

# HackerOne Sync & Auto-Reporting
HACKERONE_SYNC_INTERVAL_HOURS=12
HACKERONE_AUTO_REPORT_ENABLED=true
HACKERONE_MINIMUM_CONFIDENCE=0.80

# HackerOne Session Credentials (optional)
HUNTEROPS_USER_USERNAME=
HUNTEROPS_USER_PASSWORD=
HUNTEROPS_USER_TOKEN=
# Compatibility alias for simple session token integrations:
HUNTEROPS_SESSION_TOKEN=
HUNTEROPS_USER_COOKIE=
HUNTEROPS_USER_B_TOKEN=
HUNTEROPS_USER_B_COOKIE=
HUNTEROPS_ADMIN_TOKEN=
HUNTEROPS_ADMIN_COOKIE=

# ==========================
# SECTION 9: INTIGRITI INTEGRATION
# ==========================

# Intigriti API Credentials
INTIGRITI_API_TOKEN=<YOUR_INTIGRITI_API_TOKEN>
INTIGRITI_CLIENT_ID=<YOUR_INTIGRITI_CLIENT_ID>
INTIGRITI_CLIENT_SECRET=<YOUR_INTIGRITI_CLIENT_SECRET>

# Intigriti Program Configuration
INTIGRITI_PROGRAMS=program1,program2

# ==========================
# SECTION 10: HUNTEROPS ENGINE SETTINGS
# ==========================

# Recon Strategy
RECON_STRATEGY=multi_stage
RECON_TARGETS_PER_BATCH=50
RECON_TIMEOUT_SEC=300

# Exploitation Settings
EXPLOITATION_ENABLED=true
EXPLOITATION_CONFIDENCE_THRESHOLD=0.80
EXPLOITATION_MAX_THREADS=6

# Nuclei Configuration
NUCLEI_TEMPLATES_PATH=/opt/hunterops/wordlists/nuclei-templates
NUCLEI_SEVERITY_FILTER=critical,high,medium
NUCLEI_RETRIES=1
NUCLEI_TIMEOUT_SEC=60

# HTTPX Settings
HTTPX_WORDLISTS_PATH=/opt/hunterops/wordlists
HTTPX_CONCURRENCY=50
HTTPX_TIMEOUT_SEC=10
HTTPX_FOLLOW_REDIRECTS=true

# Subfinder Settings
SUBFINDER_PROVIDERS=passive
SUBFINDER_EXCLUDE_SOURCES=false

# ==========================
# SECTION 11: BACKUP & DISASTER RECOVERY
# ==========================

# PostgreSQL Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 0 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_COMPRESSION=gzip
BACKUP_VERIFY_ENABLED=true
BACKUP_PATH=/backups
BACKUP_FILENAME_PATTERN=hunterops-db-backup-%Y%m%d-%H%M%S.sql.gz
BACKUP_INTERVAL_SECONDS=86400
BACKUP_DAEMON_MODE=true
BACKUP_RUN_IMMEDIATELY=true

# ==========================
# SECTION 12: RUNTIME / SCHEDULING
# ==========================

# Daemon settings
RUN_INTERVAL_SECONDS=300
RUN_MAX_SECONDS=1800
RUN_JITTER_SECONDS=20
RUN_MAX_BACKOFF_SECONDS=300
MONITOR_INTERVAL_HOURS=6
MONITOR_DEADMAN_HOURS=24

# ==========================
# SECTION 13: GOVERNANCE / RULES OF ENGAGEMENT
# ==========================

# Program validation
HUNTEROPS_REQUIRE_PROGRAM_HEADERS=1
HUNTEROPS_ENFORCE_ALLOWED_HOURS=1

# User identity (legacy)
HUNTER_NAME=
HUNTER_EMAIL=
HUNTEROPS_BUG_BOUNTY_USERNAME=
HUNTEROPS_TEST_ACCOUNT_EMAIL=

# Target inputs
TARGETS_FILE=config/targets/admissions_in_scope_hosts.txt
TARGET_LIST=
SCOPE_FETCH_MAX_TARGETS=1000
SCOPE_FETCH_AUTOMATION_ONLY=1
# drop = se nao houver sinal claro de automacao permitida, o programa e descartado
SCOPE_FETCH_AUTOMATION_UNKNOWN_POLICY=drop

# ==========================
# SECTION 14: DEBUG & DEVELOPMENT
# ==========================

# Debug mode (NEVER enable in production!)
ENABLE_DEBUG=false
ENABLE_PROFILING=false
ENABLE_PYCHARM_DEBUGGER=false

# Development overrides
DEV_SKIP_SCOPE_VALIDATION=false
DEV_MOCK_LLM_RESPONSES=false
DEV_FAST_RECON_MODE=false

# ==========================
# SECTION 15: MONITORING & OOB
# ==========================

# Out-of-Band Callback Configuration
HUNTEROPS_OOB_CALLBACK_DOMAIN=
HUNTEROPS_OOB_POLL_URL=
HUNTEROPS_OOB_API_TOKEN=

# Monitoring
MONITOR_DISCORD_WEBHOOK=
HUNTEROPS_DISCORD_RECON_WEBHOOK=

# ===================================================================
# DEPLOYMENT INSTRUCTIONS
# ===================================================================
#
# 1. COPY THIS FILE:
#    cp .env.example .env
#
# 2. GENERATE STRONG PASSWORDS:
#    openssl rand -base64 32  # For POSTGRES_PASSWORD
#    openssl rand -hex 16      # For ENCRYPTION_KEY
#    openssl rand -base64 64   # For JWT_SECRET
#
# 3. FILL SENSITIVE VALUES (marked with <...>):
#    - POSTGRES_PASSWORD: 32-char base64 string
#    - ANTHROPIC_API_KEY: from console.anthropic.com
#    - HACKERONE_API_TOKEN: from h1.hackerone.com/settings/integration
#    - Discord Webhooks: from Discord Developer Portal
#    - VPS_PUBLIC_IP: your Oracle Cloud public IP
#
# 4. VALIDATE CONFIGURATION:
#    python -m hunterops.config_validation --env-file .env
#
# 5. START DOCKER COMPOSE:
#    docker-compose -f docker-compose.prod.yml up -d
#
# 6. VERIFY ALL SERVICES:
#    docker-compose -f docker-compose.prod.yml ps
#    docker logs hunterops-engine | head -50
#
# 7. ENABLE PGAUDIT EXTENSION:
#    docker exec hunterops-db psql -U hunterops -d hunterops \
#      -c "CREATE EXTENSION IF NOT EXISTS pgaudit;"
#
# 8. CHECK LOGS:
#    tail -f data/logs/structured.jsonl | jq '.'
#
# 9. SECURE PERMISSIONS:
#    chmod 600 .env .env.production
#
# 10. SETUP AUTOMATED BACKUPS (on host crontab):
#     0 20 * * * ( \
#       docker exec hunterops-db pg_dump -U hunterops hunterops | \
#       gzip > /backups/hunterops-db-backup-$(date +\%Y\%m\%d-\%H\%M\%S).sql.gz \
#     )
#
