## 13. Python Integration Code

```python
# hunterops/discord_templates.py

DISCORD_COLORS = {
    "critical": 15158332,  # RED
    "high": 16753920,      # ORANGE
    "medium": 16776960,    # YELLOW
    "low": 3447003,        # BLUE
    "info": 3447003,       # BLUE
}

DISCORD_EMOJIS = {
    "critical": "🔴",
    "high": "🟡",
    "medium": "🟠",
    "low": "🔵",
    "info": "🔵",
}

def create_finding_embed(finding: dict, confidence: float, rationale: str) -> dict:
    """Cria embed formatado para finding."""
    
    severity = finding.get("severity", "info")
    
    embed = {
        "title": f"{DISCORD_EMOJIS[severity]} {finding.get('vulnerability_type', 'Unknown').upper()}",
        "color": DISCORD_COLORS[severity],
        "fields": [
            {"name": "Program", "value": f"**{finding.get('program', 'Unknown')}**", "inline": True},
            {"name": "Severity", "value": severity.upper(), "inline": True},
            {"name": "Endpoint", "value": f"`{finding.get('endpoint', 'N/A')}`", "inline": False},
            {"name": "Confidence", "value": f"**{confidence:.0%}**", "inline": True},
            {"name": "Rationale", "value": rationale[:500], "inline": False},
            {"name": "Evidence", "value": "[Request](link) | [Response](link)", "inline": False},
        ],
        "timestamp": datetime.utcnow().isoformat() + "Z",
    }
    
    return embed

def create_discord_payload(
    embeds: list[dict],
    content: str | None = None,
    username: str = "Pinguinho",
) -> dict:
    """Cria payload final para Discord."""
    
    payload = {
        "username": username,
        "embeds": embeds,
    }
    
    if content:
        payload["content"] = content
    
    return payload
```

